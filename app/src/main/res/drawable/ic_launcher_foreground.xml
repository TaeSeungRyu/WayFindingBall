<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Star glow -->
    <path
        android:fillColor="#55FFE08A"
        android:pathData="M74,38 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />

    <!-- Star -->
    <path
        android:fillColor="#FFCB47"
        android:strokeColor="#D89A1F"
        android:strokeWidth="1.8"
        android:pathData="M74,24 L77.5,33.2 L87.3,33.7 L79.7,39.9 L82.2,49.3 L74,44 L65.8,49.3 L68.3,39.9 L60.7,33.7 L70.5,33.2 Z" />

    <!-- Ball drop shadow -->
    <path
        android:fillColor="#33000000"
        android:pathData="M22,68 A 24,24 0 1,0 70,68 A 24,24 0 1,0 22,68 Z" />

    <!-- Ball body with radial gradient (white highlight to red) -->
    <path android:pathData="M22,60 A 24,24 0 1,0 70,60 A 24,24 0 1,0 22,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="38"
                android:centerY="52"
                android:gradientRadius="36"
                android:startColor="#FFFFFFFF"
                android:endColor="#E84545" />
        </aapt:attr>
    </path>

    <!-- Ball outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#B53636"
        android:strokeWidth="2"
        android:pathData="M22,60 A 24,24 0 1,0 70,60 A 24,24 0 1,0 22,60 Z" />

    <!-- Ball top-left highlight -->
    <path
        android:fillColor="#F0FFFFFF"
        android:pathData="M33,52 A 5.5,5.5 0 1,0 44,52 A 5.5,5.5 0 1,0 33,52 Z" />
</vector>
